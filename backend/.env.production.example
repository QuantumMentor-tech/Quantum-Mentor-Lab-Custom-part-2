# ============================================================
# Quantum Mentor World — Production Environment Configuration
# backend/.env.production.example
# ============================================================

# ─── Server ─────────────────────────────────────────────────
# Set to 'production' to enforce strict security validations and headers
NODE_ENV=production
# The port your web app will listen on
PORT=5000

# ─── Database ────────────────────────────────────────────────
# Use a production hosted MySQL/MariaDB database host - do NOT use localhost XAMPP in production
DB_HOST=your-production-db-host
DB_PORT=3306
DB_NAME=your-production-db-name
DB_USER=your-production-db-user
DB_PASSWORD=your-strong-production-db-password

# ─── JWT Authentication ───────────────────────────────────────
# MUST be a long, complex random secret (minimum 32 characters, high entropy)
JWT_SECRET=replace_with_a_long_random_secret_before_launch
JWT_EXPIRES_IN=7d

# ─── Frontend URL & CORS ──────────────────────────────────────
# The main public domain where your static frontend files are hosted
FRONTEND_URL=https://your-domain.com
# Comma-separated list of approved domains allowed to make API requests (No wildcards '*')
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─── File Uploads ────────────────────────────────────────────
# Storage directory path for uploaded screenshots/media
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5

# ─── Rate Limiting ───────────────────────────────────────────
# Time window configuration in milliseconds (900000ms = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=10
CONTACT_RATE_LIMIT_MAX=5
REPORT_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=30

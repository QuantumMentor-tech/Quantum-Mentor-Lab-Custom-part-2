{
  "name": "quantum-mentor-world-backend",
  "version": "1.0.0",
  "description": "Backend API for Quantum Mentor World — Node.js, Express.js, MySQL.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "hash:password": "node scripts/generate-password-hash.js",
    "check": "node -c server.js && node -c app.js",
    "check:env": "node scripts/check-env.js",
    "check:db": "node scripts/check-db.js",
    "check:security": "node scripts/security-self-check.js",
    "check:api": "node scripts/api-smoke-test.js",
    "prelaunch": "node scripts/prelaunch-check.js",
    "backup:db": "node scripts/backup-database.js",
    "backup:uploads": "node scripts/backup-uploads.js",
    "create:production-admin": "node scripts/create-production-admin.js",
    "export:summary": "node scripts/export-project-summary.js"
  },
  "keywords": [
    "education",
    "edtech",
    "resources",
    "express",
    "mysql"
  ],
  "author": "Quantum Mentor Official",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.10.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
